# ═══════════════════════════════════════════════════
# Auto Alternance — Variables d'environnement
# ═══════════════════════════════════════════════════
# Copier ce fichier en .env et remplacer les valeurs
# cp .env.example .env
# ═══════════════════════════════════════════════════

# Remplis SEULEMENT les clés que tu as : tout slot laissé vide est
# automatiquement ignoré par le routeur LLM (aucun essai gaspillé).

# ─── Apify ──────────────────────────────────────────
# LinkedIn (les 3 zones). Un seul compte suffit : tu peux mettre la même
# valeur dans APIFY_TOKEN_LINKEDIN et APIFY_TOKEN_OTHER.
# https://console.apify.com → Settings → API tokens
APIFY_TOKEN_LINKEDIN=apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Indeed (France + Canada). Peut être identique à APIFY_TOKEN_LINKEDIN.
APIFY_TOKEN_OTHER=apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Notion ─────────────────────────────────────────
# Token d'intégration Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID de la base Notion (affiché par `python setup_notion.py`)
NOTION_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Page parent où setup_notion.py crée la base (partagée avec l'intégration)
NOTION_PARENT_PAGE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Google Gemini (jusqu'à 7 clés) ──────────────────
# Fallback LLM gratuit (Gemini 2.5 Flash Lite). Crée plusieurs clés (idéalement
# sur des projets Google Cloud différents) pour multiplier le quota gratuit.
# Remplis-en autant que tu veux ; les vides sont ignorées.
# https://aistudio.google.com/apikey → Create API Key
GEMINI_API_KEY_1=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=

# ─── Groq (1 ou 2 comptes) ───────────────────────────
# Rotation principale (rapide). 2 comptes = quota doublé ; avec un seul,
# laisse GROQ_API_KEY_2 vide (les slots correspondants sont ignorés).
# https://console.groq.com/keys → Create API Key
GROQ_API_KEY_1=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_API_KEY_2=

# ─── OpenRouter ──────────────────────────────────────
# 2 usages : (1) fallback de scoring (payant) ; (2) GÉNÉRATION CV/lettre via
# DeepSeek R1 gratuit (openrouter/deepseek/deepseek-r1:free). Recommandé si tu
# veux générer des CV. Si vide, la génération bascule sur Gemini.
# https://openrouter.ai/keys → Create Key
OPENROUTER_API_KEY=

# ─── Autres providers LLM (optionnels, pour élargir) ─
# Décommente/remplis si tu veux les brancher (voir GENERATOR_*_MODEL / LLM_QUOTAS).
# Cerebras (scoring rapide gratuit) : https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# NVIDIA NIM — génération CV/lettre (DeepSeek V4 pro). Crédits gratuits.
# https://build.nvidia.com → page du modèle → "Get API Key" (clé nvapi-...)
NVIDIA_NIM_API_KEY=
# Mistral (rédaction FR, tier gratuit) : https://console.mistral.ai
MISTRAL_API_KEY=
